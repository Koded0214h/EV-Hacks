  "IngestFnEE15D018": {
   "Type": "AWS::Lambda::Function",
   "Properties": {
    "Code": {
     "ZipFile": "\nimport json\nimport os\nimport uuid\nimport boto3\n\nkinesis = boto3.client(\"kinesis\")\nSTREAM = os.environ[\"STREAM_NAME\"]\n\nREQUIRED = (\"lat\", \"lon\", \"ts\")\n\n\ndef handler(event, _context):\n    try:\n        body = event.get(\"body\") or \"{}\"\n        if event.get(\"isBase64Encoded\"):\n            import base64\n            body = base64.b64decode(body).decode()\n        payload = json.loads(body)\n    except Exception as e:\n        return {\"statusCode\": 400, \"body\": json.dumps({\"error\": f\"bad json: {e}\"})}\n\n    missing = [f for f in REQUIRED if f not in payload]\n    if missing:\n        return {\"statusCode\": 400, \"body\": json.dumps({\"error\": f\"missing: {missing}\"})}\n\n    # Anonymise — never propagate raw driver identity past this point\n    raw_id = str(payload.pop(\"driver_id\", uuid.uuid4().hex))\n    partition_key = raw_id\n\n    record = {\n        \"lat\": float(payload[\"lat\"]),\n        \"lon\": float(payload[\"lon\"]),\n        \"ts\": payload[\"ts\"],\n        \"speed\": payload.get(\"speed\"),\n        \"battery\": payload.get(\"battery\"),\n        \"kind\": payload.get(\"kind\", \"ping\"),\n        \"ingested_at\": __import__(\"datetime\").datetime.utcnow().isoformat() + \"Z\",\n    }\n\n    kinesis.put_record(\n        StreamName=STREAM,\n        Data=(json.dumps(record) + \"\\n\").encode(),\n        PartitionKey=partition_key,\n    )\n    return {\"statusCode\": 200, \"body\": json.dumps({\"ok\": True})}\n"
    },
    "Environment": {
     "Variables": {
      "STREAM_NAME": {
       "Ref": "PingStreamD8F95A44"
      }
     }
    },
    "FunctionName": "evh-ingest",
    "Handler": "index.handler",
    "MemorySize": 256,
    "Role": {
     "Fn::GetAtt": [
      "IngestFnServiceRoleCDCC94EA",
      "Arn"
     ]
    },
    "Runtime": "python3.12",
    "Tags": [
     {
      "Key": "Hackathon",
      "Value": "OneWithAI-2026"
     },
     {
      "Key": "Owner",
      "Value": "240404075@live.unilag.edu.ng"
     },
     {
      "Key": "Project",
      "Value": "EVHacks"
     },
     {
      "Key": "Team",
      "Value": "EVHacks"
     }
    ],
    "Timeout": 5
   },
   "DependsOn": [
    "IngestFnServiceRoleDefaultPolicy2D066896",
    "IngestFnServiceRoleCDCC94EA"
   ],
   "Metadata": {
    "aws:cdk:path": "EvhIngestStack/IngestFn/Resource"
   }
  },
